# Dependencies
/node_modules
.pnp
.pnp.*

# Next.js
/.next/
/out/
next-env.d.ts

# Production build
/build

# Testing
/coverage

# Env / secrets — NEVER commit (NDA-binding). Only `.env.example` is tracked.
.env
.env*.local
.env.development
.env.staging
.env.production

# Editor / OS
.DS_Store
*.pem
*.tsbuildinfo

# Claude local settings (personal, per-machine)
.claude/settings.local.json

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Prisma generated client
/src/generated/

# Legacy Apps Script backend — the .gs source has a hardcoded client ID + admin emails. NEVER
# commit it. The legacy client (legacy/index.html) is kept as a tracked parity reference (it only
# contains the already-public web-app URL + Google *client ID*, no secrets).
/legacy/*.gs
