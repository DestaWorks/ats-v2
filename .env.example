# DestaHealth ATS — environment variables (example).
# Copy to `.env` for local dev. NEVER commit real secrets (NDA-binding).
# A DISTINCT set of values exists per environment: local · staging · production (DECISIONS D6).

# --- App ---
# The environment's own origin. Local: http://localhost:3000
# Staging: https://staging.zyx.com  ·  Production: https://zyx.com
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET=""            # openssl rand -base64 32

# --- Database (Supabase Postgres) — separate project per env (staging vs prod) ---
DATABASE_URL=""                  # postgres://...  (staging or prod, never shared)

# --- Auth: Google OAuth (register redirect URIs for ALL origins: localhost, staging, prod) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI (Claude / Anthropic) — server-side only ---
ANTHROPIC_API_KEY=""
