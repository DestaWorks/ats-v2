# DestaHealth ATS — environment variables (example).
# Copy to `.env` for local dev. NEVER commit real secrets (NDA-binding).
# A DISTINCT set of values exists per environment: local · staging · production (DECISIONS D6).

# --- App ---
# The environment's own origin. Local: http://localhost:3000
# Staging: https://staging.zyx.com  ·  Production: https://zyx.com
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET=""            # openssl rand -base64 32

# --- Database (Supabase Postgres) — separate project per env (staging vs prod) ---
DATABASE_URL=""                  # postgres://...  (staging or prod, never shared)

# --- Auth: Google OAuth (register redirect URIs for ALL origins: localhost, staging, prod) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI (provider-agnostic, server-side only) ---
# The model is a "provider/model" string; swap providers with ONE env var, no code change.
# Supported providers: anthropic · openai · google (gemini). Set the key for whichever you use.
AI_MODEL="anthropic/claude-opus-4-8"   # e.g. openai/gpt-5, google/gemini-2.5-pro
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- Field encryption for PHI at rest (activate-by-key) ---
# AES-256-GCM key (base64, 32 bytes) for encrypting sensitive columns (licenseNumber, résumé
# extractedText/extractedData) at the repository boundary. UNSET → fields are stored as plaintext
# (dev/demo, identical to today). Set it in staging/prod to encrypt all NEW writes; existing
# plaintext rows keep reading and are encrypted the next time they're written.
# Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=""
