// DestaHealth ATS — Prisma schema.
// Wave 0.3 brings ONLY the auth tables (Better Auth models + our `role`) and a minimal
// `access_request` (the request-access screen). Feature tables land in their own waves.
//
// Runtime connects via the Supabase transaction pooler (DATABASE_URL, pg driver adapter);
// migrations use the session pooler (DIRECT_URL, set in prisma.config.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Better Auth core models (+ admin plugin fields) ---

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  // RBAC (DECISIONS D3): one fixed role per account; `admin` is a role value.
  role          String    @default("Associate")
  // admin plugin
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  mentions      Mention[]

  @@map("user")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String? // admin plugin
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// --- Access requests (request-access screen; full admin CRUD in Wave 5) ---

model AccessRequest {
  id           String   @id @default(cuid())
  name         String
  email        String
  organization String?
  message      String?
  status       String   @default("pending") // pending | approved | declined
  createdAt    DateTime @default(now())

  @@index([status])
  @@map("access_request")
}

// --- Audit trail (Wave 0.5) ---
// Append-only activity log. `before`/`after` snapshots may contain PII/PHI, so reads are
// capability-gated (`viewAuditLog`); rows are written inside the same transaction as the
// mutation they record (see server/db/audit.ts) so the trail can't drift from the data.

model ActivityLog {
  id       String   @id @default(cuid())
  entity   String
  entityId String
  actor    String // the acting user's id
  action   String
  before   Json?
  after    Json?
  at       DateTime @default(now())

  @@index([entity, entityId])
  @@index([actor, at])
  // Wave 2.5 Activity Log (AL-2): the whole-log `at desc` sort + date-range scans, and the
  // action-filtered sort (action is the highest-selectivity filter). `entity` (~3 values) and
  // `actor`-scoped reads intentionally ride `[at,id]` / the existing `[actor,at]` — keeping
  // write-amplification minimal on this append-only, high-write table.
  @@index([at, id])
  @@index([action, at, id])
  @@map("activity_log")
}

// --- Recruiting pipeline (Wave 1.1) ---
// Candidate + Client + StageHistory. Vocabulary enums (credential, status, track, source,
// population, setting, tags, licenseStatus) are stored as String/String[] and validated in
// zod against the `lib/constants` unions (matches `User.role`) — keeps vocab churn out of
// migrations. Status is a stable CODE + numeric `stageOrder` mirror (never the label). Actor
// columns are plain `String` ids (mirrors `activity_log.actor`) — legacy actors may not
// resolve to a `User` row at ETL. Soft-delete (`deletedAt`) is filtered by default at the
// repository layer. `licenseNumber` is sensitive PII — DTO-gated (`viewCredentials`) and
// encrypted at rest at the repository boundary when `FIELD_ENCRYPTION_KEY` is set.

model Client {
  id         String       @id @default(cuid())
  legacyId   String?      @unique
  name       String
  capacity   Int?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt   DateTime?
  candidates  Candidate[]
  rules       ClientRules? // 1:1 back-relation — per-client scoring/matching rules
  sourceLeads SourceLead[] @relation("LeadTargetClient") // pre-pipeline leads targeting this client

  @@index([deletedAt])
  @@map("clients")
}

/// Per-client scoring/matching rules — DATA, not code (DECISIONS: scoring rules live in a table,
/// consumed by the pure `scoreCandidate(candidate, clientRules)` / `getAutoDisqualify`). Exactly one
/// row per Client (1:1); deleting a Client cascades its rules. Empty arrays mean "no constraint on
/// this dimension" (that dimension contributes nothing to `max`). Editing UI is a later (CRM) wave;
/// seeded from `BASE_CLIENT_RULES` for now.
model ClientRules {
  id             String   @id @default(cuid())
  clientId       String   @unique
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  states         String[] @default([]) // e.g. ["CT","NJ"] — matched against candidate.licenseState
  creds          String[] @default([]) // e.g. ["PMHNP","MD"] — matched against candidate.credential
  pops           String[] @default([]) // populations, e.g. ["Child/Adolescent"]
  settings       String[] @default([]) // e.g. ["Hybrid","Outpatient"]
  priority       String? // "HIGH" | "MED" | "STANDARD" (display / future weighting)
  autoDisqualify String[] @default([]) // human-readable hard-DQ reasons (feeds getAutoDisqualify context)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId])
  @@map("client_rules")
}

model Candidate {
  id                  String          @id @default(cuid())
  legacyId            String?         @unique
  // identity / contact (PII)
  name                String
  email               String?
  phone               String?
  city                String?
  state               String?
  employer            String?
  yearsExp            Int?
  // clinical profile (scoring/gate inputs)
  credential          String?
  population          String?
  setting             String?
  telehealthPref String? // legacy TelehealthPref — preference, distinct from setting
  track               String          @default("Clinical")
  source              String?
  tags                String[]        @default([])
  outreachAttempts    Int             @default(0)
  // license / verification
  licenseState        String?
  licenseNumber       String? // SENSITIVE — DTO-gated + encrypted at rest when FIELD_ENCRYPTION_KEY is set
  licenseStatus       String          @default("Not Verified")
  licenseExpiry       DateTime?
  licenseVerifiedAt   DateTime?
  licenseVerifiedById String?
  // pipeline (code + ordinal + denormalized timing)
  status              String          @default("NEW_CANDIDATE")
  stageOrder          Int             @default(0)
  stageEnteredAt      DateTime        @default(now())
  placedAt            DateTime?
  // client
  clientId            String?
  client              Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // lifecycle
  createdById         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  deletedById         String?
  stageHistory        StageHistory[]
  documents           Document[]
  notes               CandidateNote[]
  // Sourcing (Wave 2.6) back-relations. `promotedFromLead` is the lead this candidate was promoted
  // FROM (0/1, `@unique` on the lead side); `outreachLog` is the shared outreach table (candidate
  // side is written later — the `outreachAttempts` Int column above is the DENORM count, not this).
  promotedFromLead    SourceLead?       @relation("LeadPromotion")
  outreachLog         OutreachAttempt[]

  @@index([status])
  @@index([clientId])
  @@index([deletedAt])
  @@index([licenseExpiry])
  @@index([status, deletedAt])
  @@index([email])
  // Keyset pagination (search-pagination wave). Composite indexes serve the (where..., orderBy)
  // tuples of the list + board keyset queries so deep pages stay O(page), not a growing scan.
  @@index([deletedAt, createdAt, id]) // list, createdAt sorts (Newest/Oldest)
  @@index([status, deletedAt, createdAt, id]) // board per-column keyset (status + createdAt desc, id)
  @@index([status, deletedAt, stageEnteredAt]) // stuck/overdue thresholds + listStaleActive
  @@map("candidates")
}

// Uploaded documents (résumés today; licenses/other later). Wave 1.2 (design S-1/S-2):
// stores metadata + client-extracted text + captured structured JSON. Physical PDF bytes are
// deferred to Wave 6 — `storageKey` stays null until the Supabase bucket is wired.
model Document {
  id       String  @id @default(cuid())
  legacyId String? @unique // ETL upsert (legacy ResumeFileID)

  // ownership — NULLABLE: a doc can exist pre-match (uploaded, not yet attached).
  // Cascade: a résumé is pure candidate PII — a hard purge takes its documents with it.
  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // classification (validated vs DOCUMENT_TYPES in zod; stored as String)
  type             String @default("resume")
  originalFilename String
  mimeType         String
  sizeBytes        Int?

  // storage references (S-2)
  storageKey String? // Supabase object path — NULL until Wave 6
  legacyUrl  String? // legacy Google Drive URL, carried at ETL

  // captured extraction (SENSITIVE — DTO-gated on viewCredentials; never logged; encrypted at
  // rest at the repository boundary when FIELD_ENCRYPTION_KEY is set)
  extractedText String?
  extractedData Json?

  // lifecycle
  uploadedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?

  @@index([candidateId])
  @@index([deletedAt])
  @@index([type])
  @@map("documents")
}

// Candidate notes (Wave 2.2). Body is user text — stored RAW and rendered as escaped plain text
// client-side (NEVER dangerouslySetInnerHTML — fixes the legacy stored-XSS). noteType is a two-value
// vocab (internal | external) validated in zod. Role-scoped visibility is enforced SERVER-SIDE in the
// read (server/services/note.service.ts), never shipped-then-hidden. Cascade: a note is candidate PII,
// so a hard purge takes its notes with it.
model CandidateNote {
  id          String    @id @default(cuid())
  legacyId    String?   @unique // deferred ETL backfill (idempotent upsert)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  authorId   String // acting user's id (mirrors activity_log.actor)
  authorName String? // denormalized display name (legacy notes may lack a User row)
  body       String // RAW user text — never rendered as HTML
  noteType   String  @default("internal") // internal | external (validated vs constant union in zod)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?

  mentions Mention[]

  @@index([candidateId])
  @@index([candidateId, createdAt])
  @@index([deletedAt])
  @@map("candidate_notes")
}

// One @mention notification: note author tagged `recipient` in a candidate note. Created
// SERVER-SIDE by re-parsing the stored body (never a client-supplied recipient list — the legacy
// `ats_notify_mention` trusted the client). `readAt` is the read state the bell/alerts panel keys
// off (DATA-MODEL "mentions(recipient, read)"). `candidateId` is denormalized for the deep link.
model Mention {
  id     String        @id @default(cuid())
  noteId String
  note   CandidateNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  candidateId String
  recipientId String
  recipient   User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  readAt      DateTime?

  @@index([recipientId, readAt])
  @@map("mentions")
}

model StageHistory {
  id             String    @id @default(cuid())
  candidateId    String
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fromStatus     String?
  toStatus       String
  fromStageOrder Int?
  toStageOrder   Int
  enteredAt      DateTime  @default(now())
  actorId        String

  @@index([candidateId])
  @@index([candidateId, enteredAt])
  @@map("stage_history")
}

// --- Sourcing (Wave 2.6) ---
// Pre-pipeline lead funnel. `status` is the canonical LeadStatus LABEL (L-1), validated in zod vs
// LEAD_STATUSES and canonicalized with `normalizeLeadStatus` on write — no numeric stage code
// (leads have no gates/ordinal funnel). Vocab (source/credential/state/tags) is FREE TEXT here, not
// the candidate strict-vocab enums — the promote mapper coerces to the enums (dropping non-matches).
// Promote creates a Candidate in Postgres (D2) and back-links it (`promotedCandidateId @unique`).
model SourceLead {
  id       String  @id @default(cuid())
  legacyId String? @unique // deferred ETL backfill (idempotent upsert)

  // identity / contact (PII)
  name        String
  email       String?
  phone       String?
  linkedinUrl String?

  // sourcing context (free text — NOT the candidate strict-vocab enums)
  credential String? // raw job title / credential text
  state      String?
  source     String?
  tags       String[] @default([])
  notes      String?

  // target client (optional) — reuses the small clients table for the promote → candidate.clientId carry
  clientId String?
  client   Client? @relation("LeadTargetClient", fields: [clientId], references: [id], onDelete: SetNull)

  // lifecycle status + denormalized outreach (L-4)
  status              String    @default("Sourced") // a LeadStatus LABEL
  outreachCount       Int       @default(0) // TRUE attempt count (unbounded; status caps at O3)
  lastOutreachAt      DateTime?
  // Channel of the newest attempt (denorm, kept by logOutreach + syncOutreachDenorm) — the
  // inventory's legacy "Last touch" cell ("LinkedIn · 20d") without an N+1 latest-attempt read.
  lastOutreachChannel String?
  respondedAt    DateTime?
  // Snooze: excluded from stuck-lead alerts until this date (legacy `SnoozedUntil`). Date-aware
  // EVERYWHERE (the legacy brief checked raw truthiness — an expired snooze suppressed forever).
  snoozedUntil   DateTime?

  // promote back-link (set once, on promote)
  promotedCandidateId String?    @unique
  promotedCandidate   Candidate? @relation("LeadPromotion", fields: [promotedCandidateId], references: [id], onDelete: SetNull)

  // lifecycle
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?

  outreachAttempts OutreachAttempt[]

  @@index([status])
  @@index([deletedAt])
  @@index([email]) // dedupe/search
  @@index([clientId])
  @@index([deletedAt, createdAt, id]) // keyset list (createdAt_desc, id tiebreak)
  @@map("source_leads")
}

// ONE table for BOTH lead and candidate outreach (L-3). This slice writes leadId only; candidateId
// exists for candidate_log_outreach later (no migration then). Cascade on both FKs: an attempt is a
// child of whichever entity owns it and is destroyed with a hard purge of that parent.
model OutreachAttempt {
  id       String  @id @default(cuid())
  legacyId String? @unique // deferred ETL (splits the legacy OutreachAttempts JSON blob into rows)

  leadId String?
  lead   SourceLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  channel String // email | phone | linkedin | other (validated vs OUTREACH_CHANNELS in zod)
  at      DateTime @default(now())
  note    String?
  actorId String

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([candidateId])
  @@index([actorId, at]) // DECISIONS: outreach_attempts(actor, day) — the CRM/daily-log perf index
  @@map("outreach_attempts")
}
